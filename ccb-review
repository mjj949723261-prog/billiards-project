#!/bin/zsh
set -euo pipefail

cd "$(dirname "$0")"

run_step() {
  local label="$1"
  shift
  if ! "$@"; then
    echo "[ccb-review] ${label} 失败，已暂停，请先处理后再继续。" >&2
    exit 1
  fi
}

if [[ $# -lt 1 ]]; then
  echo "Usage: ./ccb-review '<改动说明>'"
  exit 1
fi

change_desc="$*"
lead_prompt="$(cat ./.ccb/prompts/lead.md)"
builder_prompt="$(cat ./.ccb/prompts/builder.md)"
reviewer_prompt="$(cat ./.ccb/prompts/reviewer.md)"

run_step "通知 reviewer" ccb ask reviewer "${reviewer_prompt}

任务：审查这段改动，优先指出 bug、风险、行为变化和缺失测试。
改动说明：${change_desc}"
run_step "等待 reviewer 回复" ccb pend reviewer

run_step "通知 lead" ccb ask lead "${lead_prompt}

任务：把 reviewer 的问题按优先级整理，并给出处理顺序。
改动说明：${change_desc}"
run_step "等待 lead 回复" ccb pend lead

run_step "通知 builder" ccb ask builder "${builder_prompt}

任务：只针对前两项问题给出修改方案。
改动说明：${change_desc}"
run_step "等待 builder 回复" ccb pend builder
